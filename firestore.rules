rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all direct client-side access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Phones collection: accessed securely via our backend server-side API proxy (using the Client SDK)
    match /phones/{phoneId} {
      allow read, write: if true;
    }

    // Sales collection: accessed securely via our backend server-side API proxy (using the Client SDK)
    match /sales/{saleId} {
      allow read, write: if true;
    }
  }
}
